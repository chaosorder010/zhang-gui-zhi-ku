<mxfile host="Electron" pages="6">
  <diagram id="Ganb6Rev2eW85tMZt1zX" name="项目简介">
    <mxGraphModel dx="774" dy="611" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="690" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;掌柜智库&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;掌柜智库是一个企业级智能知识库系统，基于 &lt;strong&gt;RAG（检索增强生成）&lt;/strong&gt; 技术，旨在为垂直领域（如电子产品手册、维修指南、技术文档等）提供精准、智能的知识检索与问答服务&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="110" y="30" width="480" height="80" as="geometry" />
        </mxCell>
        <mxCell id="3" value="&lt;h3 data-heading=&quot;1.3 核心功能特性&quot;&gt;1.3 核心功能特性&lt;/h3&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;功能模块&lt;/th&gt;&lt;th&gt;描述&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;文档智能导入&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;支持 PDF/Markdown 文件上传，自动解析、切分、向量化&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;混合向量检索&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;稠密向量 + 稀疏向量混合检索&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;多路召回融合&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;向量检索 + HyDE + Web 搜索&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;智能重排序&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Reranker 模型重排序，断崖检测动态截断&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;流式问答&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;SSE 实时推送，逐字输出答案&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;会话历史管理&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;MongoDB 存储对话历史，支持上下文连续对话&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" style="text;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="110" y="160" width="410" height="310" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="zm5yEoY_9jS9C9JvyaC0" name="技术选型">
    <mxGraphModel dx="774" dy="611" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="690" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="D6mpG9MiTUImR0vGfO38-1" value="&lt;h3 data-heading=&quot;2.3 技术栈选型&quot;&gt;2.3 技术栈选&lt;/h3&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;类别&lt;/th&gt;&lt;th&gt;技术选型&lt;/th&gt;&lt;th&gt;说明&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;后端框架&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;FastAPI + Uvicorn&lt;/td&gt;&lt;td&gt;异步高性能 HTTP 服务，自动生成接口文档，高并发适配AI推理接口场景&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;工作流引擎&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;LangGraph&lt;/td&gt;&lt;td&gt;有状态图编排框架，支持多轮工具调用、分支判断、记忆持久化，搭建智能体流程&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;大语言模型&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;qwen-flash / qwen3-vl-flash&lt;/td&gt;&lt;td&gt;通义千问轻量化高速文本大模型 + 多模态视觉大模型，支持图文问答、长文本生成&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;向量嵌入&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;BGE-M3 / text-embedding-v4&lt;/td&gt;&lt;td&gt;双嵌入模型；BGE-M3同时输出稠密+稀疏向量，支持混合检索；text-embedding-v4通用高精度语义向量化&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;重排序模型&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;BGE-Reranker-Large / qwen3-rerank&lt;/td&gt;&lt;td&gt;检索后精细打分重排，过滤语义无关文档，大幅提升知识库问答精准度&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;向量数据库&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Milvus&lt;/td&gt;&lt;td&gt;高性能分布式向量检索引擎，海量文档向量存储、近似相似度快速召回，适配RAG检索场景&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;文档数据库&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;MongoDB&lt;/td&gt;&lt;td&gt;非结构化文档数据库，灵活拓展字段，存储对话历史&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;对象存储&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;MinIO&lt;/td&gt;&lt;td&gt;兼容S3协议轻量对象存储，统一管理上传PDF、图片、附件等二进制文件资源&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;PDF解析&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;MinerU&lt;/td&gt;&lt;td&gt;专业文档解析工具，精准还原PDF图文、表格、公式结构，输出干净可检索Markdown文本&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;前端&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;HTML + CSS + JS&lt;/td&gt;&lt;td&gt;无前端框架原生开发，轻量化、低部署成本，实现对话交互、文件上传、结果展示页面&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" style="text;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="760" height="440" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="nP1N0iIm0Cn-QWVV8zbo" name="AI/ML 框架与模型">
    <mxGraphModel dx="774" dy="611" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="690" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="&lt;h3 data-heading=&quot;3.2 AI/ML 框架与模型&quot;&gt;3.2 AI/ML 框架与模型&lt;/h3&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;框架/模型&lt;/th&gt;&lt;th&gt;官网地址&lt;/th&gt;&lt;th&gt;作用&lt;/th&gt;&lt;th&gt;使用位置&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;LangChain&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;https://python.langchain.com&lt;/td&gt;&lt;td&gt;LLM 应用框架，统一 LLM 调用接口&lt;/td&gt;&lt;td&gt;各 LLM 调用节点&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;LangGraph&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;https://langchain-ai.github.io/langgraph&lt;/td&gt;&lt;td&gt;工作流编排框架，构建 DAG 流程&lt;/td&gt;&lt;td&gt;主图编排（导入/查询）&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;BGE-M3&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;https://huggingface.co/BAAI/bge-m3&lt;/td&gt;&lt;td&gt;混合向量嵌入模型（稠密+稀疏）&lt;/td&gt;&lt;td&gt;向量化节点、向量检索节点&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;BGE-Reranker&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;https://huggingface.co/BAAI/bge-reranker-large&lt;/td&gt;&lt;td&gt;重排序模型（交叉编码器）&lt;/td&gt;&lt;td&gt;Rerank重排序节点&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;FlagEmbedding&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;https://github.com/FlagOpen/FlagEmbedding&lt;/td&gt;&lt;td&gt;嵌入模型工具库&lt;/td&gt;&lt;td&gt;向量化、重排序&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;MinerU&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;https://github.com/opendatalab/MinerU&lt;/td&gt;&lt;td&gt;PDF 转 Markdown 工具（支持公式、表格等复杂排版提取）&lt;/td&gt;&lt;td&gt;PDF转换节点&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;qwen3-vl-flash&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;https://bailian.console.aliyun.com/&lt;/td&gt;&lt;td&gt;多模态视觉语言大模型，支持图文理解、视觉问答&lt;/td&gt;&lt;td&gt;多模态理解、MD图片处理节点&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;text-embedding-v4&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;https://bailian.console.aliyun.com/&lt;/td&gt;&lt;td&gt;通用高精度文本向量嵌入模型（稠密+稀疏）&lt;/td&gt;&lt;td&gt;向量化节点、向量检索节点&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;qwen3-rerank&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;https://bailian.console.aliyun.com/&lt;/td&gt;&lt;td&gt;大模型级重排序模型，对检索结果做高精度语义重排&lt;/td&gt;&lt;td&gt;Rerank重排序节点&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" id="DOqdyL6VUPj6ptYjQjtX-1">
          <mxCell style="text;whiteSpace=wrap;html=1;" vertex="1" parent="1">
            <mxGeometry x="30" y="110" width="640" height="460" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
