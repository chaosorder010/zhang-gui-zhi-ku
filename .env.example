# ── 应用基础 ──
APP_NAME="zhang-gui-zhi-ku"
APP_ENV=dev
APP_DEBUG=true
HOST=0.0.0.0
PORT=8000

# ── LLM 配置 (OpenAI 兼容, 可换智谱/通义/DeepSeek 等) ──
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── MinerU 文档解析 API (https://mineru.net) ──
MINERU_API_KEY=your-mineru-token
MINERU_BASE_URL=https://mineru.net/api/v4

# ── Milvus 向量库 ──
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=zgzk

# ── CORS ──
CORS_ORIGINS=["*"]

# ── 对话历史保留轮数 ──
HISTORY_MAX_TURNS=10
