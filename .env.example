# ── 应用基础 ──
APP_NAME="zhang-gui-zhi-ku"
APP_ENV=dev
APP_DEBUG=true
HOST=0.0.0.0
PORT=8000

# ── LLM 配置 (OpenAI 兼容, 可换智谱/通义/DeepSeek 等) ──
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── CORS ──
CORS_ORIGINS=["*"]

# ── 对话历史保留轮数 ──
HISTORY_MAX_TURNS=10
